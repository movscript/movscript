{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://movscript.dev/schemas/agent-settings-snapshot-v1.schema.json",
  "title": "Agent Settings snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "schemaUrl",
    "exportedAt"
  ],
  "properties": {
    "schema": {
      "const": "movscript.agent.settings.snapshot.v1"
    },
    "schemaVersion": {
      "const": 1
    },
    "schemaUrl": {
      "const": "https://movscript.dev/schemas/agent-settings-snapshot-v1.schema.json"
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time"
    },
    "modelConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "modelConfigId": { "type": "number" },
        "apiKind": {
          "type": "string",
          "enum": ["openai_chat_completions", "openai_responses", "anthropic_messages"]
        },
        "baseURL": { "type": "string" },
        "useForChat": { "type": "boolean" },
        "useForPlanner": { "type": "boolean" }
      }
    },
    "defaultProfileId": { "type": "string", "minLength": 1 },
    "skillPolicy": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillPolicyItem" }
    },
    "toolPolicy": {
      "type": "array",
      "items": { "$ref": "#/$defs/toolPolicyItem" }
    },
    "activeRunPresetId": { "type": "string", "minLength": 1 },
    "runPresets": {
      "type": "array",
      "items": { "$ref": "#/$defs/runPreset" }
    }
  },
  "$defs": {
    "skillPolicyItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "enabled"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" }
      }
    },
    "toolPolicyItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mode"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["allow", "deny"] },
        "approval": { "type": "string", "enum": ["never", "always", "on_write"] }
      }
    },
    "runPreset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "permissionMode",
        "autoPlan",
        "maxToolCalls",
        "maxIterations",
        "planMaxWorkers",
        "planMaxTaskAttempts",
        "planWorkerTimeoutMs"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "permissionMode": { "type": "string", "enum": ["ask", "suggest", "auto"] },
        "autoPlan": { "type": "boolean" },
        "maxToolCalls": { "type": "number" },
        "maxIterations": { "type": "number" },
        "planMaxWorkers": { "type": "number" },
        "planMaxTaskAttempts": { "type": "number" },
        "planWorkerTimeoutMs": { "type": "number" }
      }
    }
  }
}
