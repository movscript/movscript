{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://movscript.local/schemas/agent-compact-contract-v1.schema.json",
  "title": "Agent compact model parameter contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "input_requirements", "supported_param_keys", "supported_params"],
  "properties": {
    "contract_version": {
      "const": 1
    },
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "model_config_id": {
      "type": "integer",
      "minimum": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "short_name": {
      "type": "string",
      "minLength": 1
    },
    "logical_model_id": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "accepts_image_input": {
      "type": "boolean"
    },
    "input_requirements": {
      "$ref": "#/$defs/inputRequirements"
    },
    "supported_param_keys": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "supported_params": {
      "type": "array",
      "items": { "$ref": "#/$defs/param" }
    },
    "params_schema_loaded": {
      "type": "boolean"
    },
    "params_schema_rule_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "jsonScalar": {
      "type": ["string", "number", "boolean"]
    },
    "paramType": {
      "enum": ["select", "number", "boolean", "string"]
    },
    "inputRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": -1 }
      }
    },
    "inputRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "video"],
      "properties": {
        "image": { "$ref": "#/$defs/inputRequirement" },
        "video": { "$ref": "#/$defs/inputRequirement" }
      }
    },
    "conditionalEnum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when_param", "when_value", "options"],
      "properties": {
        "when_param": { "type": "string", "minLength": 1 },
        "when_value": { "$ref": "#/$defs/jsonScalar" },
        "options": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "conditionalConst": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when_param", "when_value", "value"],
      "properties": {
        "when_param": { "type": "string", "minLength": 1 },
        "when_value": { "$ref": "#/$defs/jsonScalar" },
        "value": { "$ref": "#/$defs/jsonScalar" }
      }
    },
    "requiresValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["param", "value"],
      "properties": {
        "param": { "type": "string", "minLength": 1 },
        "value": { "$ref": "#/$defs/jsonScalar" }
      }
    },
    "param": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/paramType" },
        "options": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "enum": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonScalar" },
          "minItems": 1,
          "uniqueItems": true
        },
        "default": { "$ref": "#/$defs/jsonScalar" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number", "exclusiveMinimum": 0 },
        "description": { "type": "string", "minLength": 1 },
        "conflicts_with": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "conditional_enum": {
          "type": "array",
          "items": { "$ref": "#/$defs/conditionalEnum" },
          "minItems": 1
        },
        "conditional_const": {
          "type": "array",
          "items": { "$ref": "#/$defs/conditionalConst" },
          "minItems": 1
        },
        "requires_value": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiresValue" },
          "minItems": 1
        }
      }
    }
  }
}
