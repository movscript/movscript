{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://movscript.local/schemas/agent-param-validation-audit-v1.schema.json",
  "title": "Agent generation parameter validation audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_version",
    "model_config_id",
    "model_contract_loaded",
    "params_schema_loaded",
    "submitted_extra_params"
  ],
  "properties": {
    "audit_version": {
      "const": 1
    },
    "model_config_id": {
      "type": "integer",
      "minimum": 1
    },
    "model_contract_loaded": {
      "type": "boolean"
    },
    "params_schema_loaded": {
      "type": "boolean"
    },
    "params_schema_rule_count": {
      "type": "integer",
      "minimum": 0
    },
    "input_requirements": {
      "$ref": "#/$defs/inputRequirements"
    },
    "submitted_inputs": {
      "$ref": "#/$defs/submittedInputs"
    },
    "supported_params": {
      "$ref": "#/$defs/stringArray"
    },
    "provided_extra_params": {
      "$ref": "#/$defs/stringArray"
    },
    "submitted_extra_params": {
      "$ref": "#/$defs/stringArray"
    },
    "dropped_extra_params": {
      "$ref": "#/$defs/stringArray"
    },
    "dropped_top_level_params": {
      "$ref": "#/$defs/stringArray"
    },
    "drop_reasons": {
      "type": "object",
      "additionalProperties": {
        "enum": ["unsupported_extra_param", "unsupported_top_level_param", "parse_error"]
      }
    },
    "renamed_extra_params": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "extra_params_parse_error": {
      "type": "string",
      "minLength": 1
    },
    "preflight_errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/preflightError"
      },
      "minItems": 1
    },
    "input_preflight_errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inputPreflightError"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "jsonScalarOrNull": {
      "type": ["string", "number", "boolean", "null"]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "inputRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": -1
        }
      }
    },
    "inputRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "video"],
      "properties": {
        "image": {
          "$ref": "#/$defs/inputRequirement"
        },
        "video": {
          "$ref": "#/$defs/inputRequirement"
        }
      }
    },
    "submittedInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "video"],
      "properties": {
        "image": {
          "type": "integer",
          "minimum": 0
        },
        "video": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "preflightError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "field", "message"],
      "properties": {
        "code": {
          "enum": [
            "INVALID_PARAMETER_TYPE",
            "INVALID_PARAMETER_OPTION",
            "INVALID_PARAMETER_RANGE",
            "INVALID_PARAMETER_COMBINATION"
          ]
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "allowed_values": {
          "type": "array",
          "items": {
            "type": ["string", "number", "boolean"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "suggested_fix": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonScalarOrNull"
          },
          "minProperties": 1
        }
      }
    },
    "inputPreflightError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "field", "message", "required_min", "allowed_max", "actual_count"],
      "properties": {
        "code": {
          "const": "INVALID_INPUT_COUNT"
        },
        "field": {
          "enum": ["image", "video"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "required_min": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_max": {
          "type": "integer",
          "minimum": -1
        },
        "actual_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
