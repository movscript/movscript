{
  "openapi": "3.1.0",
  "info": {
    "title": "Movscript API",
    "version": "1.0.0",
    "description": "Stable contract seed for critical Movscript backend APIs. Expand this file before wiring new generated frontend or plugin clients."
  },
  "servers": [
    {
      "url": "http://localhost:8765"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "responses": {
      "APIError": {
        "description": "API error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/APIError"
            }
          }
        }
      }
    },
    "schemas": {
      "APIError": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "action": { "type": "string" }
        },
        "required": ["code", "message"]
      },
      "User": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer" },
          "username": { "type": "string" },
          "system_role": { "type": "string" }
        },
        "required": ["ID", "username", "system_role"]
      },
      "AuthRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["username", "password"]
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/User" },
          "token": { "type": "string" },
          "token_type": { "type": "string", "const": "Bearer" },
          "expires_at": { "type": "string", "format": "date-time" }
        },
        "required": ["user", "token", "token_type", "expires_at"]
      },
      "Project": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "owner_id": { "type": "integer" },
          "status": { "type": "string" },
          "total_episodes": { "type": "integer" },
          "pipeline_template": { "type": "string" }
        },
        "required": ["ID", "name", "owner_id", "status"]
      },
      "ProjectCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string" },
          "total_episodes": { "type": "integer" },
          "pipeline_template": { "type": "string" }
        },
        "required": ["name"]
      },
      "ProjectMember": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer" },
          "project_id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "role": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        },
        "required": ["ID", "project_id", "user_id", "role"]
      },
      "ProjectMemberCreate": {
        "type": "object",
        "properties": {
          "user_id": { "type": "integer" },
          "role": { "type": "string" }
        },
        "required": ["user_id"]
      },
      "RawResource": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "mime_type": { "type": "string" },
          "size": { "type": "integer" },
          "owner_id": { "type": "integer" },
          "project_id": { "type": "integer" }
        },
        "required": ["ID", "name"]
      },
      "GenJob": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer" },
          "job_type": { "type": "string" },
          "status": { "type": "string" },
          "model_config_id": { "type": "integer" },
          "feature_key": { "type": "string" },
          "result_resource_id": { "type": "integer" },
          "error": { "type": "string" }
        },
        "required": ["ID", "job_type", "status"]
      },
      "GenJobCreate": {
        "type": "object",
        "properties": {
          "job_type": { "type": "string" },
          "model_config_id": { "type": "integer" },
          "feature_key": { "type": "string" },
          "prompt": { "type": "string" },
          "input_resource_ids": { "type": "array", "items": { "type": "integer" } },
          "extra_params": { "type": "object", "additionalProperties": true }
        },
        "required": ["job_type", "model_config_id"]
      },
      "Plugin": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer" },
          "plugin_key": { "type": "string" },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "enabled": { "type": "boolean" }
        },
        "required": ["ID", "plugin_key", "name", "version", "enabled"]
      },
      "PluginImport": {
        "type": "object",
        "properties": {
          "manifest_json": { "type": "string" },
          "path": { "type": "string" }
        }
      },
      "AuditLog": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer" },
          "request_id": { "type": "string" },
          "actor_id": { "type": "integer" },
          "action": { "type": "string" },
          "target_type": { "type": "string" },
          "target_id": { "type": "string" },
          "project_id": { "type": "integer" },
          "metadata": { "type": "string" }
        },
        "required": ["ID", "action"]
      },
      "PaginatedAuditLogs": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/AuditLog" } },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "page_size": { "type": "integer" }
        },
        "required": ["items", "total", "page", "page_size"]
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Backend health",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" } }, "required": ["status"] } } }
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "operationId": "register",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthRequest" } } } },
        "responses": { "201": { "description": "Registered", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } }, "400": { "$ref": "#/components/responses/APIError" } }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "operationId": "login",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthRequest" } } } },
        "responses": { "200": { "description": "Logged in", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } }, "401": { "$ref": "#/components/responses/APIError" } }
      }
    },
    "/api/v1/projects": {
      "get": {
        "operationId": "listProjects",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Projects", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Project" } } } } } }
      },
      "post": {
        "operationId": "createProject",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectCreate" } } } },
        "responses": { "201": { "description": "Project", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } } }
      }
    },
    "/api/v1/projects/{id}": {
      "get": {
        "operationId": "getProject",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Project", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } } }
      }
    },
    "/api/v1/projects/{id}/members": {
      "get": {
        "operationId": "listProjectMembers",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Members", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ProjectMember" } } } } } }
      },
      "post": {
        "operationId": "addProjectMember",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectMemberCreate" } } } },
        "responses": { "201": { "description": "Member", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectMember" } } } } }
      }
    },
    "/api/v1/resources": {
      "get": {
        "operationId": "listResources",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Resources", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/RawResource" } } } } } }
      }
    },
    "/api/v1/gen-jobs": {
      "get": {
        "operationId": "listGenJobs",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Generation jobs", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/GenJob" } } } } } }
      },
      "post": {
        "operationId": "createGenJob",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenJobCreate" } } } },
        "responses": { "201": { "description": "Generation job", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenJob" } } } } }
      }
    },
    "/api/v1/plugins": {
      "get": {
        "operationId": "listPlugins",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Plugins", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Plugin" } } } } } }
      },
      "post": {
        "operationId": "importPlugin",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PluginImport" } } } },
        "responses": { "200": { "description": "Plugin", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Plugin" } } } }, "201": { "description": "Plugin", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Plugin" } } } } }
      }
    },
    "/api/v1/admin/audit-logs": {
      "get": {
        "operationId": "listAuditLogs",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "actor_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "action", "in": "query", "schema": { "type": "string" } },
          { "name": "target_type", "in": "query", "schema": { "type": "string" } },
          { "name": "target_id", "in": "query", "schema": { "type": "string" } },
          { "name": "project_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Audit logs", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedAuditLogs" } } } } }
      }
    }
  }
}
