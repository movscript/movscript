{
  "schema": "movscript.agent.profile.v1",
  "id": "movscript.profile.catalog-default",
  "version": "1.0.0",
  "name": "MovScript Default Profile",
  "description": "Default task-driven MovScript agent profile backed by target-state packs.",
  "enabledPacks": [
    "movscript.pack.core",
    "movscript.pack.drafts"
  ],
  "persona": "movscript.persona.default",
  "enabledWorkflows": [
    "movscript.workflow.proposal-first",
    "movscript.workflow.script-writing",
    "movscript.workflow.project-progress",
    "movscript.workflow.storyboard-gap-review"
  ],
  "enabledPolicies": [
    "movscript.policy.safe-drafts",
    "movscript.policy.approval-boundaries",
    "movscript.policy.platform-concepts"
  ],
  "toolGrants": [
    { "name": "movscript_get_current_context", "mode": "allow", "approval": "never" },
    { "name": "movscript_list_projects", "mode": "allow", "approval": "never" },
    { "name": "movscript_read_project_scripts", "mode": "allow", "approval": "never" },
    { "name": "movscript_list_drafts", "mode": "allow", "approval": "never" },
    { "name": "movscript_read_draft", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_draft", "mode": "allow", "approval": "never" },
    { "name": "movscript_update_draft", "mode": "allow", "approval": "never" },
    { "name": "movscript_search_memories", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_memory", "mode": "allow", "approval": "never" },
    { "name": "movscript_create_memory", "mode": "allow", "approval": "never" },
    { "name": "movscript_delete_memory", "mode": "allow", "approval": "always" },
    { "name": "movscript_list_agent_bundles", "mode": "allow", "approval": "never" },
    { "name": "movscript_inspect_agent_bundle", "mode": "allow", "approval": "never" },
    { "name": "movscript_enable_agent_bundle", "mode": "allow", "approval": "always" },
    { "name": "movscript_reload_agent_catalog", "mode": "allow", "approval": "always" },
    { "name": "movscript_request_user_input", "mode": "allow", "approval": "never" }
  ],
  "limits": {
    "maxActiveWorkflows": 2,
    "maxToolCallsPerTurn": 16,
    "systemPromptCharLimit": 32000
  }
}
