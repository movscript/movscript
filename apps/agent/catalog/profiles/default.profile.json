{
  "schema": "movscript.agent.profile.v1",
  "id": "movscript.profile.default",
  "version": "1.0.0",
  "name": "MovScript Default Profile",
  "description": "默认 MovScript agent profile，显式启用 core、draft 和 MovScript capability packs。",
  "enabledPacks": [
    "movscript.pack.agent-core",
    "movscript.pack.drafts",
    "movscript.pack.movscript"
  ],
  "persona": "movscript.persona.default",
  "enabledWorkflows": [
    "movscript.workflow.memory-access",
    "movscript.workflow.planner-subagents",
    "movscript.workflow.draft-lifecycle",
    "movscript.workflow.project-progress",
    "movscript.workflow.script-reading",
    "movscript.workflow.proposal-first",
    "movscript.workflow.project-standards-proposal",
    "movscript.workflow.setting-proposal",
    "movscript.workflow.asset-proposal",
    "movscript.workflow.setting-prep",
    "movscript.workflow.production-proposal",
    "movscript.workflow.asset-candidate-generation",
    "movscript.workflow.content-unit-proposal",
    "movscript.workflow.storyboard-gap-review",
    "movscript.workflow.visual-generation"
  ],
  "enabledPolicies": [
    "movscript.policy.agent-core"
  ],
  "toolGrants": [
    { "name": "movscript_get_focus", "mode": "allow", "approval": "never" },
    { "name": "movscript_list_projects", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_project_standards", "mode": "allow", "approval": "never" },
    { "name": "movscript_read_project_scripts", "mode": "allow", "approval": "never" },
    { "name": "movscript_query_creative_references", "mode": "allow", "approval": "never" },
    { "name": "movscript_query_asset_slots", "mode": "allow", "approval": "never" },
    { "name": "movscript_query_production_context", "mode": "allow", "approval": "never" },
    { "name": "movscript_list_models", "mode": "allow", "approval": "never" },
    { "name": "movscript_attach_asset_slot_candidate", "mode": "allow", "approval": "never" },
    { "name": "movscript_attach_keyframe_candidate", "mode": "allow", "approval": "never" },
    { "name": "movscript_search_knowledge", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_knowledge", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_draft", "mode": "allow", "approval": "never" },
    { "name": "agent_file_read", "mode": "allow", "approval": "never" },
    { "name": "agent_file_search", "mode": "allow", "approval": "never" },
    { "name": "agent_file_edit", "mode": "allow", "approval": "never" },
    { "name": "agent_file_validate", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_draft_model", "mode": "allow", "approval": "never" },
    { "name": "movscript_create_draft", "mode": "allow", "approval": "never" },
    { "name": "movscript_validate_draft", "mode": "allow", "approval": "never" },
    { "name": "movscript_preview_draft_apply", "mode": "allow", "approval": "never" },
    { "name": "movscript_apply_draft", "mode": "allow", "approval": "on_write" },
    { "name": "movscript_search_memories", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_memory", "mode": "allow", "approval": "never" },
    { "name": "movscript_create_memory", "mode": "allow", "approval": "never" },
    { "name": "movscript_delete_memory", "mode": "allow", "approval": "never" },
    { "name": "movscript_inspect_agent_catalog", "mode": "allow", "approval": "never" },
    { "name": "movscript_update_active_skills", "mode": "allow", "approval": "never" },
    { "name": "movscript_create_plan", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_plan", "mode": "allow", "approval": "never" },
    { "name": "movscript_replan", "mode": "allow", "approval": "never" },
    { "name": "movscript_spawn_subagent", "mode": "allow", "approval": "never" },
    { "name": "movscript_list_subagents", "mode": "allow", "approval": "never" },
    { "name": "movscript_wait_subagent", "mode": "allow", "approval": "never" },
    { "name": "movscript_cancel_subagent", "mode": "allow", "approval": "never" },
    { "name": "runtime_operation_start", "mode": "allow", "approval": "always" },
    { "name": "runtime_operation_get", "mode": "allow", "approval": "never" },
    { "name": "runtime_operation_list", "mode": "allow", "approval": "never" },
    { "name": "runtime_operation_wait", "mode": "allow", "approval": "never" },
    { "name": "runtime_operation_cancel", "mode": "allow", "approval": "always" },
    { "name": "movscript_request_user_input", "mode": "allow", "approval": "never" }
  ],
  "limits": {
    "maxActiveWorkflows": 2,
    "systemPromptCharLimit": 32000,
    "contextWindowCharLimit": 96000,
    "maxRetrievedContextChars": 24000,
    "maxKnowledgeCharsPerRun": 8000,
    "maxKnowledgeChunksPerRun": 3,
    "maxHistoryMessages": 6,
    "maxThreadSummaryChars": 4000
  },
  "metadata": {
    "promptPolicy": {
      "projectStandards": {
        "mode": "required_for_project_work"
      },
      "finalSourceBlock": true
    }
  }
}
