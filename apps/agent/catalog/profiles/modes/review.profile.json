{
  "schema": "movscript.agent.profile.v1",
  "id": "movscript.profile.review",
  "version": "1.0.0",
  "name": "Review Agent",
  "description": "Review profile for gaps, risks, and draft quality checks.",
  "modeAlias": "review",
  "enabledPacks": ["movscript.pack.core", "movscript.pack.drafts", "movscript.pack.content-unit"],
  "persona": "movscript.persona.reviewer",
  "enabledWorkflows": [
    "movscript.workflow.storyboard-gap-review",
    "movscript.workflow.project-progress"
  ],
  "enabledPolicies": [
    "movscript.policy.safe-drafts",
    "movscript.policy.approval-boundaries",
    "movscript.policy.platform-concepts"
  ],
  "toolGrants": [
    { "name": "movscript_get_current_context", "mode": "allow", "approval": "never" },
    { "name": "movscript_read_project_scripts", "mode": "allow", "approval": "never" },
    { "name": "movscript_list_drafts", "mode": "allow", "approval": "never" },
    { "name": "movscript_get_draft", "mode": "allow", "approval": "never" },
    { "name": "movscript_read_draft", "mode": "allow", "approval": "never" },
    { "name": "movscript_request_user_input", "mode": "allow", "approval": "never" }
  ],
  "limits": { "maxActiveWorkflows": 2, "maxToolCallsPerTurn": 12, "systemPromptCharLimit": 32000 }
}
