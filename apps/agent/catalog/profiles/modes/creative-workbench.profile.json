{
  "schema": "movscript.agent.profile.v1",
  "id": "movscript.profile.creative-workbench",
  "version": "1.0.0",
  "name": "Creative Workbench Agent",
  "description": "Refines story material and reusable creative notes.",
  "modeAlias": "creative-workbench",
  "enabledPacks": ["movscript.pack.core", "movscript.pack.drafts"],
  "persona": "movscript.persona.creative-workbench",
  "enabledWorkflows": ["movscript.workflow.creative-workbench"],
  "enabledPolicies": [
    "movscript.policy.safe-drafts",
    "movscript.policy.approval-boundaries",
    "movscript.policy.platform-concepts"
  ],
  "toolGrants": [
    { "name": "movscript_get_current_context", "mode": "allow", "approval": "never" },
    { "name": "movscript_request_user_input", "mode": "allow", "approval": "never" }
  ],
  "limits": { "maxActiveWorkflows": 1, "maxToolCallsPerTurn": 8, "systemPromptCharLimit": 24000 }
}
