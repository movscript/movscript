{
  "schema": "movscript.agent.profile.v1",
  "id": "movscript.profile.setting-prep",
  "version": "1.0.0",
  "name": "Setting Prep Agent",
  "description": "Reviews and improves selected creative references.",
  "modeAlias": "setting-prep",
  "enabledPacks": ["movscript.pack.core", "movscript.pack.proposal"],
  "persona": "movscript.persona.project-orchestrator",
  "enabledWorkflows": ["movscript.workflow.setting-prep"],
  "enabledPolicies": [
    "movscript.policy.approval-boundaries",
    "movscript.policy.platform-concepts"
  ],
  "toolGrants": [
    { "name": "movscript_get_current_context", "mode": "allow", "approval": "never" },
    { "name": "movscript_request_user_input", "mode": "allow", "approval": "never" }
  ],
  "limits": { "maxActiveWorkflows": 1, "maxToolCallsPerTurn": 8, "systemPromptCharLimit": 24000 }
}
