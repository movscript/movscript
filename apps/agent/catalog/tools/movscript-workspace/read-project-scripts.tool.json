{
  "name": "movscript_read_project_scripts",
  "description": "Read scripts in the current or specified project, optionally including script body text.",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "projectId": {
        "type": "number"
      },
      "includeContent": {
        "type": "boolean"
      }
    }
  },
  "permission": "project.read",
  "risk": "read",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
