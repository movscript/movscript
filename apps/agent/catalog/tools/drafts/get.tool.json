{
  "name": "movscript_get_draft",
  "description": "按 id 读取本地 draft。返回 content、metadata、status 和本地校验结果。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "draftId"
    ],
    "properties": {
      "draftId": {
        "type": "string"
      }
    }
  },
  "permission": "draft.read",
  "risk": "read",
  "projectScoped": false,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
