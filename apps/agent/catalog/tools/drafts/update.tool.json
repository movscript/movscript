{
  "name": "movscript_update_draft",
  "description": "编辑、校验或 dry-run 一个本地 draft。Actions: 'patch_content'（JSON Pointer add/replace/remove）、'replace_text'（old/new string）、'replace_content'（完整 body）、'replace_fields'（title/status/metadata）、'set_status'、'validate'（仅本地 schema）、'preview_apply'（dry-run，暴露本地校验错误以及后端 apply diff/error）。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "draftId"
    ],
    "properties": {
      "draftId": {
        "type": "string"
      },
      "action": {
        "type": "string",
        "enum": [
          "replace_fields",
          "replace_content",
          "patch_content",
          "replace_text",
          "set_status",
          "validate",
          "preview_apply"
        ]
      },
      "status": {
        "type": "string",
        "enum": [
          "draft",
          "accepted",
          "rejected",
          "applied",
          "superseded"
        ]
      },
      "title": {
        "type": "string"
      },
      "content": {
        "type": "string"
      },
      "target": {
        "type": "object",
        "additionalProperties": true
      },
      "metadata": {
        "type": "object",
        "additionalProperties": true
      },
      "rejectedReason": {
        "type": "string"
      },
      "expectedUpdatedAt": {
        "type": "string"
      },
      "oldString": {
        "type": "string"
      },
      "newString": {
        "type": "string"
      },
      "replaceAll": {
        "type": "boolean"
      },
      "previewApply": {
        "type": "boolean"
      },
      "validateOnly": {
        "type": "boolean"
      },
      "ops": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "op",
            "path"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "add",
                "replace",
                "remove"
              ]
            },
            "path": {
              "type": "string"
            },
            "value": {}
          }
        }
      },
      "targetEntityType": {
        "type": "string"
      },
      "targetEntityId": {
        "type": [
          "string",
          "number"
        ]
      },
      "targetField": {
        "type": "string"
      },
      "currentValue": {},
      "proposedValue": {}
    }
  },
  "permission": "draft.write",
  "risk": "draft",
  "projectScoped": false,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime",
  "capability": "对一个本地 draft 执行 patch、replace、validate 或 dry-run preview_apply。"
}
