{
  "name": "movscript_list_drafts",
  "description": "列出当前或指定项目的本地 drafts，可按 kind 或 status 过滤。创建新 draft 前，用它查找已有 draft。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "projectId": {
        "type": "number"
      },
      "kind": {
        "type": "string"
      },
      "status": {
        "type": "string"
      },
      "threadId": {
        "type": "string"
      },
      "runId": {
        "type": "string"
      },
      "limit": {
        "type": "number"
      }
    }
  },
  "permission": "draft.read",
  "risk": "read",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
