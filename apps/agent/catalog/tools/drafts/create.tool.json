{
  "name": "movscript_create_draft",
  "description": "创建本地 draft，并写出真实 draft JSON 文件。返回的 draft.filePath 是后续正文编辑的权威路径；创建后正文修改应使用 agent 文件编辑工具直接改该文件，再调用 movscript_validate_draft 或 movscript_preview_draft_apply。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "kind",
      "content"
    ],
    "properties": {
      "kind": {
        "type": "string",
        "enum": [
          "script_split_proposal",
          "script",
          "asset_slot",
          "content_unit",
          "prompt",
          "note",
          "pipeline",
          "segment",
          "scene_moment",
          "setting_proposal",
          "asset_proposal",
          "project_standards_proposal",
          "production_proposal",
          "content_unit_proposal"
        ]
      },
      "title": {
        "type": "string"
      },
      "content": {
        "type": "string",
        "description": "Draft 初始正文。创建 proposal draft 时必须传 JSON.stringify 后的 canonical JSON 字符串；顶层必须包含 schema 字段。创建成功后不要再通过工具参数替换正文，改用 draft.filePath 的真实文件编辑。"
      },
      "projectId": {
        "type": "number"
      },
      "productionId": {
        "type": "number"
      },
      "source": {
        "type": "object",
        "additionalProperties": true
      },
      "target": {
        "type": "object",
        "additionalProperties": true
      },
      "seed": {
        "type": "object",
        "additionalProperties": true,
        "description": "来自 DraftDomainModel/MCP 的 seed 契约或已 hydrate seed 摘要。创建修改类 proposal 时应记录 mode、include、modelRef、sourceVersions/hydratedAt。"
      },
      "metadata": {
        "type": "object",
        "additionalProperties": true
      },
      "proposal": {
        "type": "boolean"
      }
    }
  },
  "permission": "draft.write",
  "risk": "draft",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime",
  "capability": "为所选 schema kind 创建本地审阅 draft 或 proposal draft。"
}
