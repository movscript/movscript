{
  "name": "movscript_create_draft",
  "description": "创建本地 draft。kind 字段选择 draft schema。设置 proposal:true 会创建带 schema 校验和推断 target/source metadata 的 proposal draft；不设置 proposal:true 则创建普通 draft。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "kind",
      "content"
    ],
    "properties": {
      "kind": {
        "type": "string",
        "enum": [
          "script_split_proposal",
          "script",
          "asset_slot",
          "storyboard_line",
          "content_unit",
          "prompt",
          "note",
          "pipeline",
          "segment",
          "scene_moment",
          "setting_proposal",
          "asset_proposal",
          "project_proposal",
          "production_proposal",
          "content_unit_proposal"
        ]
      },
      "title": {
        "type": "string"
      },
      "content": {
        "type": "string"
      },
      "projectId": {
        "type": "number"
      },
      "productionId": {
        "type": "number"
      },
      "source": {
        "type": "object",
        "additionalProperties": true
      },
      "target": {
        "type": "object",
        "additionalProperties": true
      },
      "seed": {
        "type": "object",
        "additionalProperties": true,
        "description": "来自 DraftDomainModel/MCP 的 seed 契约或已 hydrate seed 摘要。创建修改类 proposal 时应记录 mode、include、modelRef、sourceVersions/hydratedAt。"
      },
      "metadata": {
        "type": "object",
        "additionalProperties": true
      },
      "proposal": {
        "type": "boolean"
      }
    }
  },
  "permission": "draft.write",
  "risk": "draft",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime",
  "capability": "为所选 schema kind 创建本地审阅 draft 或 proposal draft。"
}
