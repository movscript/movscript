{
  "tools": [
    {
      "name": "movscript_submit_script_split_draft",
      "description": "Create a structured script_split review draft from production analysis and store it as a local runtime artifact. The tool accepts structured fields and does not require the model to stringify JSON into assistant content.",
      "permission": "draft.write",
      "risk": "draft",
      "source": "runtime",
      "category": "script_split",
      "projectScoped": true,
      "requiresApprovalByDefault": false,
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "projectId",
          "sourceTitle",
          "sourceSummary",
          "sourceScript",
          "globalSettings",
          "episodeDrafts"
        ],
        "properties": {
          "projectId": {
            "type": "number"
          },
          "draftTitle": {
            "type": "string"
          },
          "sourceTitle": {
            "type": "string"
          },
          "sourceSummary": {
            "type": "string"
          },
          "sourceScript": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "title",
              "summary",
              "sourceType",
              "lineCount"
            ],
            "properties": {
              "title": {
                "type": "string",
                "description": "Source script title only. Do not include source body text."
              },
              "summary": {
                "type": "string",
                "description": "Short source-level summary. Do not copy or quote the original script body."
              },
              "sourceType": {
                "type": "string",
                "enum": [
                  "raw"
                ],
                "description": "Always raw for line-number based splitting."
              },
              "lineCount": {
                "type": "number",
                "minimum": 1,
                "description": "Total number of numbered source lines. This is the only source-body reference allowed."
              }
            }
          },
          "globalSettings": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "storyWorld",
              "coreRules",
              "characterRelationships",
              "keyCharacters",
              "keyLocations",
              "keyProps",
              "continuityNotes"
            ],
            "properties": {
              "storyWorld": {
                "type": "string"
              },
              "coreRules": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "characterRelationships": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "keyCharacters": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "keyLocations": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "keyProps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "continuityNotes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "episodeDrafts": {
            "type": "array",
            "minItems": 1,
            "description": "Each episode must reference the source body only by startLine/endLine. Never include content, text, body, or original lines.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "order",
                "title",
                "summary",
                "globalContext",
                "startLine",
                "endLine",
                "action",
                "existingScriptId"
              ],
              "properties": {
                "order": {
                  "type": "number"
                },
                "title": {
                  "type": "string"
                },
                "summary": {
                  "type": "string",
                  "description": "Episode-level summary. Do not copy the original episode body."
                },
                "globalContext": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "storyWorld",
                    "coreRules",
                    "characterRelationships",
                    "keyCharacters",
                    "keyLocations",
                    "keyProps",
                    "continuityNotes",
                    "episodeRelevance"
                  ],
                  "properties": {
                    "storyWorld": {
                      "type": "string"
                    },
                    "coreRules": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "characterRelationships": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "keyCharacters": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "keyLocations": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "keyProps": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "continuityNotes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "episodeRelevance": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "startLine": {
                  "type": "number",
                  "minimum": 1,
                  "description": "First source line included in this episode. Use line numbers only; do not pass body text."
                },
                "endLine": {
                  "type": "number",
                  "minimum": 1,
                  "description": "Last source line included in this episode. Use line numbers only; do not pass body text."
                },
                "action": {
                  "type": "string",
                  "enum": [
                    "create",
                    "update"
                  ]
                },
                "existingScriptId": {
                  "type": [
                    "number",
                    "null"
                  ]
                }
              }
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "number"
          }
        }
      },
      "defaultGrant": {
        "name": "movscript_submit_script_split_draft",
        "mode": "allow",
        "approval": "never"
      }
    }
  ]
}
