{
  "name": "movscript_cancel_subagent",
  "description": "Cancel a child worker subagent subtree owned by the current planner run.",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "subagentName": { "type": "string" },
      "runId": { "type": "string" },
      "taskId": { "type": "string" },
      "reason": { "type": "string" }
    }
  },
  "permission": "agent.subagent.write",
  "risk": "write",
  "projectScoped": false,
  "defaults": { "grant": "allow", "approval": "never" },
  "source": "runtime",
  "capability": "Cancel planner-owned worker subagents.",
  "allowedRunRoles": ["planner"]
}
