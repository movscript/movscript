{
  "name": "movscript_get_generation_job",
  "description": "检查一个 AI 图片或视频生成任务，并在可用时返回当前状态、进度提示、输出资源和媒体预览数据。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "jobId"
    ],
    "properties": {
      "jobId": {
        "type": [
          "string",
          "number"
        ]
      },
      "projectId": {
        "type": "number"
      }
    }
  },
  "permission": "generation.read",
  "risk": "read",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
