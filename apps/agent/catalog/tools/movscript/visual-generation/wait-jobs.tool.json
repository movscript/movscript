{
  "name": "movscript_wait_generation_jobs",
  "description": "等待一个或多个 AI 图片或视频生成任务进入终态，或直到等待超时。用于替代 agent 反复调用 movscript_get_generation_job 轮询状态。支持 all/any 模式，并返回 completed、pending、failed、cancelled 的结构化列表。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "jobIds": {
        "type": "array",
        "items": {
          "type": [
            "string",
            "number"
          ]
        },
        "minItems": 1,
        "description": "要等待的生成任务 ID 列表。"
      },
      "jobId": {
        "type": [
          "string",
          "number"
        ],
        "description": "单任务等待的兼容别名；提供 jobIds 时忽略。"
      },
      "projectId": {
        "type": "number"
      },
      "mode": {
        "type": "string",
        "enum": [
          "all",
          "any"
        ],
        "description": "all 等全部任务进入终态；any 等任一任务进入终态。默认 all。"
      },
      "timeout_ms": {
        "type": "number",
        "description": "最长等待时间。超时返回 pending，不把任务视为失败。"
      },
      "heartbeat_ms": {
        "type": "number",
        "description": "保留给事件流心跳/状态回调。当前实现用于结果 metadata。"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "status",
      "done",
      "jobIds",
      "completed",
      "pending",
      "failed",
      "cancelled",
      "message"
    ],
    "properties": {
      "status": {
        "type": "string",
        "enum": [
          "completed",
          "partial",
          "timeout",
          "failed",
          "cancelled"
        ]
      },
      "done": {
        "type": "boolean"
      },
      "jobIds": {
        "type": "array",
        "items": {
          "type": "number"
        }
      },
      "completed": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "pending": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "failed": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "cancelled": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "output_resource_ids": {
        "type": "array",
        "items": {
          "type": "number"
        }
      },
      "jobs": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "message": {
        "type": "string"
      }
    }
  },
  "permission": "generation.read",
  "risk": "read",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
