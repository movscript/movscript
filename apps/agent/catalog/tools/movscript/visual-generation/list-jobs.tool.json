{
  "name": "movscript_list_generation_jobs",
  "description": "列出当前 project 最近的 AI 图片或视频生成任务，便于 agent 监控排队中和运行中的工作。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "projectId": {
        "type": "number"
      },
      "status": {
        "type": "string"
      },
      "limit": {
        "type": "number"
      }
    }
  },
  "permission": "generation.read",
  "risk": "read",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
