{
  "name": "movscript_list_models",
  "description": "列出某个 capability 或后端 AI feature key 可用的图片/视频模型。通用生成优先使用 capability：文生图用 image，图生图用 image_edit，文生视频用 video，图生视频用 video_i2v，视频生视频用 video_v2v。后端 feature key 是产品路由 key，例如 ref_image_gen、ref_video_gen、canvas_image、canvas_video、style_transfer、multi_angle；不要把 workflow template key（例如 image-generation、text-generation）当作 feature 传入。结果包含 public model_id，以及 contract_version 1 的 model_contracts，其中包括 capabilities、input_requirements、supported_param_keys、supported_params 和 params_schema 规则数量；input_requirements 对应该次查询的 capability。创建任务时使用所选 contract 的 model_id。生成前使用此工具选择有效模型，并且只询问该模型要求的字段。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "capability": {
        "type": "string"
      },
      "feature": {
        "type": "string",
        "description": "可选的后端 AI feature key。有效示例：ref_image_gen、ref_video_gen、canvas_image、canvas_video、style_transfer、multi_angle、motion_imitation、video_edit。不要使用 image-generation 这类 workflow template key。"
      },
      "feature_key": {
        "type": "string",
        "description": "feature 的别名；只能传后端 AI feature key，不能传 workflow template key。"
      },
      "provider_variants": {
        "type": "boolean",
        "description": "为 true 时，包含 provider 专用模型变体。"
      },
      "include_provider_variants": {
        "type": "boolean",
        "description": "provider_variants 的别名。"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "count",
      "queries",
      "model_contracts",
      "models"
    ],
    "properties": {
      "count": {
        "type": "number"
      },
      "queries": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "model_contracts": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "contract_version",
            "model_id",
            "capabilities",
            "input_requirements",
            "supported_param_keys",
            "supported_params"
          ],
          "properties": {
            "contract_version": {
              "type": "number",
              "const": 1
            },
            "model_id": {
              "type": "string",
              "description": "传给异步 generation_job runtime operation request 的公开模型 ID。"
            },
            "display_name": {
              "type": "string"
            },
            "short_name": {
              "type": "string"
            },
            "logical_model_id": {
              "type": "string",
              "description": "model_id 的兼容别名。"
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "accepts_image_input": {
              "type": "boolean"
            },
            "input_requirements": {
              "type": "object",
              "required": [
                "image",
                "video"
              ],
              "properties": {
                "image": {
                  "type": "object",
                  "required": [
                    "min",
                    "max"
                  ],
                  "properties": {
                    "min": {
                      "type": "number"
                    },
                    "max": {
                      "type": "number"
                    }
                  }
                },
                "video": {
                  "type": "object",
                  "required": [
                    "min",
                    "max"
                  ],
                  "properties": {
                    "min": {
                      "type": "number"
                    },
                    "max": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "supported_param_keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "supported_params": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "key"
                ],
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "select",
                      "number",
                      "boolean",
                      "string"
                    ]
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "conflicts_with": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "conditional_enum": {
                    "type": "array"
                  },
                  "conditional_const": {
                    "type": "array"
                  },
                  "requires_value": {
                    "type": "array"
                  }
                }
              }
            },
            "params_schema_loaded": {
              "type": "boolean"
            },
            "params_schema_rule_count": {
              "type": "number"
            }
          }
        }
      },
      "models": {
        "type": "array"
      }
    }
  },
  "permission": "generation.read",
  "risk": "read",
  "projectScoped": false,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
