{
  "name": "movscript_list_models",
  "description": "列出某个 capability 或 feature 可用的图片/视频模型。结果包含 raw models，以及 contract_version 1 的 model_contracts，其中包括 capabilities、input_requirements、supported_param_keys、supported_params 和 params_schema 规则数量。模型按 contract 划分范围：相同 logical_model_id 的条目仍可能暴露不同 model_config_id 和不同 contracts，因此创建任务时必须使用所选 contract 的精确 model_config_id。生成前使用此工具选择有效模型，并且只询问该模型要求的字段。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "capability": {
        "type": "string"
      },
      "feature": {
        "type": "string"
      },
      "feature_key": {
        "type": "string",
        "description": "feature 的别名。"
      },
      "provider_variants": {
        "type": "boolean",
        "description": "为 true 时，包含 provider 专用模型变体。"
      },
      "include_provider_variants": {
        "type": "boolean",
        "description": "provider_variants 的别名。"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "count",
      "queries",
      "model_contracts",
      "models"
    ],
    "properties": {
      "count": {
        "type": "number"
      },
      "queries": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "model_contracts": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "contract_version",
            "model_config_id",
            "capabilities",
            "input_requirements",
            "supported_param_keys",
            "supported_params"
          ],
          "properties": {
            "contract_version": {
              "type": "number",
              "const": 1
            },
            "id": {
              "type": "number"
            },
            "model_config_id": {
              "type": "number",
              "description": "传给 movscript_create_generation_job 的精确 ID。"
            },
            "display_name": {
              "type": "string"
            },
            "short_name": {
              "type": "string"
            },
            "logical_model_id": {
              "type": "string",
              "description": "仅用于分组 metadata。不要用它替代 model_config_id。"
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "accepts_image_input": {
              "type": "boolean"
            },
            "input_requirements": {
              "type": "object",
              "required": [
                "image",
                "video"
              ],
              "properties": {
                "image": {
                  "type": "object",
                  "required": [
                    "min",
                    "max"
                  ],
                  "properties": {
                    "min": {
                      "type": "number"
                    },
                    "max": {
                      "type": "number"
                    }
                  }
                },
                "video": {
                  "type": "object",
                  "required": [
                    "min",
                    "max"
                  ],
                  "properties": {
                    "min": {
                      "type": "number"
                    },
                    "max": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "supported_param_keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "supported_params": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "key"
                ],
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "select",
                      "number",
                      "boolean",
                      "string"
                    ]
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "conflicts_with": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "conditional_enum": {
                    "type": "array"
                  },
                  "conditional_const": {
                    "type": "array"
                  },
                  "requires_value": {
                    "type": "array"
                  }
                }
              }
            },
            "params_schema_loaded": {
              "type": "boolean"
            },
            "params_schema_rule_count": {
              "type": "number"
            }
          }
        }
      },
      "models": {
        "type": "array"
      }
    }
  },
  "permission": "generation.read",
  "risk": "read",
  "projectScoped": false,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
