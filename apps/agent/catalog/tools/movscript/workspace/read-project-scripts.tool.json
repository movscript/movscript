{
  "name": "movscript_read_project_scripts",
  "description": "读取当前或指定 project 中的 scripts，可选包含 script 正文。",
  "inputSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "projectId": {
        "type": "number"
      },
      "includeContent": {
        "type": "boolean"
      }
    }
  },
  "permission": "project.read",
  "risk": "read",
  "projectScoped": true,
  "defaults": {
    "grant": "allow",
    "approval": "never"
  },
  "source": "runtime"
}
