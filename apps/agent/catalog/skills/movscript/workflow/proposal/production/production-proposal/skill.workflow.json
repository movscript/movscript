{
  "id": "movscript.workflow.production-proposal",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Production Proposal",
  "description": "以本地审阅 draft 的形式起草 production 层 segment、scene-moment 和 production-ready gap proposals，并把缺失 project 设定或素材槽回退到上游 proposal。",
  "priority": 860,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "production_proposal"
    },
    {
      "kind": "keyword",
      "any": [
        "制作提案",
        "制作编排",
        "production proposal",
        "production_proposal"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_get_draft_model",
    "tool://movscript_create_draft",
    "tool://agent_file_read",
    "tool://agent_file_search",
    "tool://agent_file_edit",
    "tool://movscript_validate_draft",
    "tool://movscript_preview_draft_apply",
    "tool://movscript_apply_draft",
    "tool://movscript_get_draft",
    "tool://movscript_query_creative_references",
    "tool://movscript_query_asset_slots",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "schemaRefs": [
    "schema://movscript.production_proposal.v1"
  ],
  "outputContract": "回复 draftId、projectId、productionId、draft status、最近一次 preview_apply 的 ok/stage、segments/scene moments 数量和未解决上游缺口。",
  "instructionTemplatePath": "instruction.md"
}
