{
  "id": "movscript.workflow.asset-candidate-generation",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Asset Candidate Generation",
  "description": "在 asset slot、设定和验收标准明确后，创建并监控可审阅的图片或视频候选，并在成功后加入候选集。",
  "priority": 770,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "asset_candidate_generation"
    },
    {
      "kind": "keyword",
      "any": [
        "生成素材",
        "图片候选",
        "视频候选",
        "asset candidate"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_query_creative_references",
    "tool://movscript_query_asset_slots",
    "tool://movscript_query_production_context",
    "tool://movscript_get_draft_model",
    "tool://movscript_request_user_input",
    "tool://movscript_list_models",
    "tool://runtime_operation_start",
    "tool://runtime_operation_get",
    "tool://runtime_operation_wait",
    "tool://runtime_operation_list",
    "tool://movscript_attach_asset_slot_candidate",
    "tool://runtime_operation_cancel"
  ],
  "toolScope": "intersect",
  "outputContract": "返回已选 asset target、候选 prompt 方向、已有设定/素材检查结果、所需模型能力、生成 operationId、output_resource_id 列表、每个 output_resource_id 的候选写入结果、阻塞项和下一步动作。",
  "instructionTemplatePath": "instruction.md"
}
