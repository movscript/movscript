{
  "id": "movscript.workflow.content-unit-media-proposal",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Content Unit Media Proposal",
  "description": "为已有 content units 起草媒体、关键帧和生成约束计划，不创建生成任务。",
  "priority": 820,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "content_unit_media_proposal"
    },
    {
      "kind": "keyword",
      "any": [
        "媒体方案",
        "关键帧",
        "content unit media",
        "content_unit_media_proposal"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_query_production_context",
    "tool://movscript_query_creative_references",
    "tool://movscript_query_asset_slots",
    "tool://movscript_create_draft",
    "tool://movscript_update_draft",
    "tool://movscript_get_draft",
    "tool://movscript_list_drafts",
    "tool://movscript_search_knowledge",
    "tool://movscript_get_knowledge",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "schemaRefs": [
    "schema://movscript.content_unit_media_proposal.v1"
  ],
  "outputContract": "返回 draftId、content unit 目标、计划媒体/关键帧数量、validation/preview 状态、阻塞项和下一步动作。",
  "instructionTemplatePath": "instruction.md"
}
