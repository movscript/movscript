{
  "id": "movscript.workflow.content-unit-proposal",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Content Unit Proposal",
  "description": "以本地审阅 draft 形式起草内容单元结构、剧情推进、情绪推进、钩子和节拍 proposal。",
  "priority": 830,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "content_unit_proposal"
    },
    {
      "kind": "keyword",
      "any": [
        "内容单元",
        "分镜",
        "镜头参数",
        "视觉计划",
        "视觉调度",
        "调度图",
        "blocking",
        "storyboard brief",
        "导演分镜",
        "普通导演",
        "content unit",
        "content_unit_proposal"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_query_production_context",
    "tool://movscript_query_creative_references",
    "tool://movscript_query_asset_slots",
    "tool://movscript_create_draft",
    "tool://agent_file_read",
    "tool://agent_file_search",
    "tool://agent_file_edit",
    "tool://movscript_validate_draft",
    "tool://movscript_preview_draft_apply",
    "tool://movscript_apply_draft",
    "tool://movscript_get_draft",
    "tool://movscript_search_knowledge",
    "tool://movscript_get_knowledge",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "schemaRefs": [
    "schema://movscript.content_unit_proposal.v1"
  ],
  "outputContract": "返回 draftId、productionId、content unit 数量、validation/preview 状态、结构缺口和下一步媒体或素材工作建议。",
  "metadata": {
    "expertiseRefs": [
      "movscript.expertise.storyboard.general-director"
    ]
  },
  "instructionTemplatePath": "instruction.md"
}
