{
  "id": "movscript.workflow.storyboard-gap-review",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Storyboard Gap Review",
  "description": "审阅已选内容的分镜、关键帧、素材或媒体规划缺口，并建议下一步 workflow。",
  "priority": 650,
  "enabled": true,
  "triggers": [
    {
      "kind": "keyword",
      "any": [
        "分镜缺口",
        "storyboard gap",
        "镜头缺口",
        "关键帧缺口"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_list_drafts",
    "tool://movscript_get_draft",
    "tool://movscript_search_knowledge",
    "tool://movscript_get_knowledge",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "outputContract": "按目标返回缺口、来源、严重度、建议 workflow 和需要用户确认的问题。",
  "instructionTemplatePath": "instruction.md"
}
