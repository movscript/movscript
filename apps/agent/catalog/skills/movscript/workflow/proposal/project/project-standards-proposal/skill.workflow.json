{
  "id": "movscript.workflow.project-standards-proposal",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Project Standards Proposal",
  "description": "起草 project 层制作规范：镜头大小体系、画幅、摄影语言、视觉风格、灯光色彩、节奏规则和负面约束。",
  "priority": 900,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "project_standards_proposal"
    },
    {
      "kind": "keyword",
      "any": [
        "项目规范提案",
        "项目规范",
        "镜头大小",
        "镜头规格",
        "画幅",
        "风格规范",
        "摄影语言",
        "project standards proposal",
        "project_standards_proposal"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_get_draft_model",
    "tool://movscript_create_draft",
    "tool://movscript_update_draft",
    "tool://movscript_get_draft",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "schemaRefs": [
    "schema://movscript.project_standards_proposal.v1"
  ],
  "instructionTemplatePath": "instruction.md",
  "outputContract": "回复 draftId、projectId、draft status、项目规范摘要、validation 状态，以及尚未决定的镜头/风格约束。"
}
