{
  "id": "movscript.workflow.proposal-first",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Proposal First",
  "description": "在正式写入前，把宽泛、跨层或缺上游上下文的请求路由到最小必要的本地 proposal draft。",
  "priority": 700,
  "enabled": true,
  "triggers": [
    {
      "kind": "keyword",
      "any": [
        "提案",
        "草稿",
        "proposal",
        "draft"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_list_drafts",
    "tool://movscript_get_draft",
    "tool://movscript_create_draft",
    "tool://movscript_update_draft",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "outputContract": "返回已选择的 draft 或推荐的 draft kind、选择理由、阻塞项、下一步审阅动作和应交接的 workflow。",
  "instructionTemplatePath": "instruction.md"
}
