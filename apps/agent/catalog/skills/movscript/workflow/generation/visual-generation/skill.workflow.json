{
  "id": "movscript.workflow.visual-generation",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Visual Generation",
  "description": "在生成目标、参考资源、模型能力和审批边界明确后，创建内容单元视觉、关键帧、图片或视频生成任务并监控结果。",
  "priority": 780,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "visual_generation"
    },
    {
      "kind": "keyword",
      "any": [
        "生成图片",
        "生成视频",
        "生成关键帧",
        "关键帧候选",
        "画面锚点候选",
        "关键帧",
        "keyframe generation",
        "keyframe candidate",
        "visual anchor candidate",
        "keyframe_generation",
        "出图",
        "出视频",
        "编辑图片",
        "图片编辑",
        "改图",
        "修图",
        "参考图",
        "这张图",
        "这张图片",
        "让这张",
        "image edit",
        "image_edit",
        "edit image",
        "image generation",
        "video generation"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_focus",
    "tool://movscript_query_creative_references",
    "tool://movscript_query_asset_slots",
    "tool://movscript_query_production_context",
    "tool://movscript_get_draft_model",
    "tool://movscript_request_user_input",
    "tool://movscript_list_models",
    "tool://runtime_operation_start",
    "tool://runtime_operation_get",
    "tool://runtime_operation_wait",
    "tool://runtime_operation_cancel",
    "tool://movscript_attach_asset_slot_candidate",
    "tool://movscript_attach_keyframe_candidate",
    "tool://runtime_operation_list"
  ],
  "toolScope": "intersect",
  "outputContract": "返回最终任务状态、jobId、生成类型、目标实体、可用时的输出资源列表、一致性参考说明、简洁的匹配理由，以及每个 output_resource_id 的候选集写入结果。",
  "instructionTemplatePath": "instruction.md"
}
