{
  "skills": [
    {
      "id": "movscript.workflow.visual-generation",
      "kind": "workflow",
      "version": "1.0.0",
      "name": "Visual Generation",
      "description": "Creates image or video generation jobs and monitors the result.",
      "priority": 780,
      "enabled": true,
      "triggers": [
        {
          "kind": "intent",
          "id": "visual_generation"
        },
        {
          "kind": "context",
          "selector": {
            "mode": [
              "visual-generation"
            ]
          }
        },
        {
          "kind": "keyword",
          "any": [
            "生成图片",
            "生成视频",
            "出图",
            "出视频",
            "image generation",
            "video generation"
          ]
        }
      ],
      "toolRefs": [
        "tool://movscript_list_models",
        "tool://movscript_create_generation_job",
        "tool://movscript_get_generation_job",
        "tool://movscript_list_generation_jobs",
        "tool://movscript_cancel_generation_job"
      ],
      "toolScope": "intersect",
      "outputContract": "Return final job status, jobId, output resource when available, and concise fit rationale.",
      "instructionTemplatePath": "visual-generation.workflow.md"
    },
    {
      "id": "movscript.workflow.asset-candidate-generation",
      "kind": "workflow",
      "version": "1.0.0",
      "name": "Asset Candidate Generation",
      "description": "Generates reviewable visual candidates for an asset slot.",
      "priority": 770,
      "enabled": true,
      "triggers": [
        {
          "kind": "intent",
          "id": "asset_candidate_generation"
        },
        {
          "kind": "context",
          "selector": {
            "mode": [
              "asset-candidate-generation"
            ]
          }
        },
        {
          "kind": "keyword",
          "any": [
            "生成素材",
            "图片候选",
            "视频候选",
            "asset candidate"
          ]
        }
      ],
      "toolRefs": [
        "tool://movscript_list_models",
        "tool://movscript_create_generation_job",
        "tool://movscript_get_generation_job",
        "tool://movscript_list_generation_jobs",
        "tool://movscript_cancel_generation_job"
      ],
      "toolScope": "intersect",
      "outputContract": "Return jobId, status, output_resource_id when available, selected asset target, and why the candidate fits.",
      "instructionTemplatePath": "asset-candidate-generation.workflow.md"
    }
  ]
}
