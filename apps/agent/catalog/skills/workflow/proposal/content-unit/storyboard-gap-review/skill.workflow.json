{
  "id": "movscript.workflow.storyboard-gap-review",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Storyboard Gap Review",
  "description": "Reviews storyboard or media planning gaps for selected content.",
  "priority": 650,
  "enabled": true,
  "triggers": [
    {
      "kind": "keyword",
      "any": [
        "分镜缺口",
        "storyboard gap",
        "镜头缺口",
        "关键帧缺口"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_current_context",
    "tool://movscript_list_drafts",
    "tool://movscript_get_draft",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "outputContract": "Return gaps grouped by target content unit or scene, plus the next proposal or generation step.",
  "instructionTemplatePath": "instruction.md"
}
