{
  "id": "movscript.workflow.content-unit-proposal",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Content Unit Proposal",
  "description": "Draft content-unit structure proposals as local review patches.",
  "priority": 830,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "content_unit_proposal"
    },
    {
      "kind": "keyword",
      "any": [
        "内容单元",
        "content unit",
        "content_unit_proposal"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_current_context",
    "tool://movscript_create_draft",
    "tool://movscript_update_draft",
    "tool://movscript_get_draft",
    "tool://movscript_list_drafts",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "schemaRefs": [
    "schema://movscript.content_unit_proposal.v1"
  ],
  "outputContract": "Return draftId, productionId when known, content unit count, preview status, and structural gaps.",
  "instructionTemplatePath": "instruction.md"
}
