{
  "id": "movscript.workflow.project-proposal",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Project Proposal",
  "description": "Draft project-level creative reference and asset-slot proposals as local merge patches.",
  "priority": 900,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "project_proposal"
    },
    {
      "kind": "keyword",
      "any": [
        "项目提案",
        "项目设定",
        "素材需求",
        "project proposal",
        "project_proposal"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_current_context",
    "tool://movscript_create_draft",
    "tool://movscript_update_draft",
    "tool://movscript_get_draft",
    "tool://movscript_list_drafts",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "schemaRefs": [
    "schema://movscript.project_proposal.v1"
  ],
  "instructionTemplatePath": "instruction.md",
  "outputContract": "Reply with draftId, projectId, productionId when available, draft status, last preview_apply ok/stage, and concise setting/asset gaps."
}
