{
  "id": "movscript.workflow.setting-prep",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Setting Prep",
  "description": "Prepare or improve one selected creative reference.",
  "priority": 760,
  "enabled": true,
  "triggers": [
    {
      "kind": "intent",
      "id": "setting_prep"
    },
    {
      "kind": "keyword",
      "any": [
        "设定准备",
        "设定完善",
        "creative reference"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_current_context",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "outputContract": "Return the improvement suggestion, missing data points, and whether a proposal draft is needed next.",
  "instructionTemplatePath": "instruction.md"
}
