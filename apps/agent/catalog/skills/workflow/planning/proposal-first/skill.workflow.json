{
  "id": "movscript.workflow.proposal-first",
  "kind": "workflow",
  "version": "1.0.0",
  "name": "Proposal First",
  "description": "Routes broad change requests into local proposal drafts before formal writes.",
  "priority": 700,
  "enabled": true,
  "triggers": [
    {
      "kind": "keyword",
      "any": [
        "提案",
        "草稿",
        "proposal",
        "draft"
      ]
    }
  ],
  "toolRefs": [
    "tool://movscript_get_current_context",
    "tool://movscript_list_drafts",
    "tool://movscript_get_draft",
    "tool://movscript_create_draft",
    "tool://movscript_update_draft",
    "tool://movscript_request_user_input"
  ],
  "toolScope": "intersect",
  "outputContract": "Return the selected draft or recommended draft kind and the next review action.",
  "instructionTemplatePath": "instruction.md"
}
