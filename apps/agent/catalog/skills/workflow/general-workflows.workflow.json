{
  "skills": [
    {
      "id": "movscript.workflow.proposal-first",
      "kind": "workflow",
      "version": "1.0.0",
      "name": "Proposal First",
      "description": "Routes broad change requests into local proposal drafts before formal writes.",
      "priority": 700,
      "enabled": true,
      "triggers": [
        {
          "kind": "keyword",
          "any": [
            "提案",
            "草稿",
            "proposal",
            "draft"
          ]
        }
      ],
      "toolRefs": [
        "tool://movscript_get_current_context",
        "tool://movscript_list_drafts",
        "tool://movscript_get_draft",
        "tool://movscript_update_draft",
        "tool://movscript_request_user_input"
      ],
      "toolScope": "intersect",
      "outputContract": "Return the selected draft or recommended draft kind and the next review action.",
      "instructionTemplatePath": "proposal-first.workflow.md"
    },
    {
      "id": "movscript.workflow.script-writing",
      "kind": "workflow",
      "version": "1.0.0",
      "name": "Script Writing",
      "description": "Creates script text and saves it only after explicit approval.",
      "priority": 690,
      "enabled": true,
      "triggers": [
        {
          "kind": "keyword",
          "any": [
            "写剧本",
            "创建剧本",
            "保存剧本",
            "script writing",
            "create script"
          ]
        }
      ],
      "toolRefs": [
        "tool://movscript_get_current_context",
        "tool://movscript_create_script",
        "tool://movscript_request_user_input"
      ],
      "toolScope": "intersect",
      "outputContract": "Return the script status, created script id when available, and whether the save was approved.",
      "instructionTemplatePath": "script-writing.workflow.md"
    },
    {
      "id": "movscript.workflow.project-progress",
      "kind": "workflow",
      "version": "1.0.0",
      "name": "Project Progress",
      "description": "Summarizes current project progress from context, scripts, drafts, and available state.",
      "priority": 660,
      "enabled": true,
      "triggers": [
        {
          "kind": "keyword",
          "any": [
            "进度",
            "完成度",
            "project progress",
            "status"
          ]
        }
      ],
      "toolRefs": [
        "tool://movscript_get_current_context",
        "tool://movscript_read_project_scripts",
        "tool://movscript_list_drafts"
      ],
      "toolScope": "intersect",
      "outputContract": "Return verified progress, open drafts, blockers, and recommended next step.",
      "instructionTemplatePath": "project-progress.workflow.md"
    },
    {
      "id": "movscript.workflow.storyboard-gap-review",
      "kind": "workflow",
      "version": "1.0.0",
      "name": "Storyboard Gap Review",
      "description": "Reviews storyboard or media planning gaps for selected content.",
      "priority": 650,
      "enabled": true,
      "triggers": [
        {
          "kind": "keyword",
          "any": [
            "分镜缺口",
            "storyboard gap",
            "镜头缺口",
            "关键帧缺口"
          ]
        }
      ],
      "toolRefs": [
        "tool://movscript_get_current_context",
        "tool://movscript_list_drafts",
        "tool://movscript_get_draft",
        "tool://movscript_request_user_input"
      ],
      "toolScope": "intersect",
      "outputContract": "Return gaps grouped by target content unit or scene, plus the next proposal or generation step.",
      "instructionTemplatePath": "storyboard-gap-review.workflow.md"
    },
    {
      "id": "movscript.workflow.creative-workbench",
      "kind": "workflow",
      "version": "1.0.0",
      "name": "Creative Workbench",
      "description": "Refines reusable story material and creative notes.",
      "priority": 640,
      "enabled": true,
      "triggers": [
        {
          "kind": "context",
          "selector": {
            "mode": [
              "creative-workbench"
            ]
          }
        },
        {
          "kind": "keyword",
          "any": [
            "故事素材",
            "头脑风暴",
            "creative workbench",
            "brainstorm"
          ]
        }
      ],
      "toolRefs": [
        "tool://movscript_get_current_context",
        "tool://movscript_request_user_input"
      ],
      "toolScope": "intersect",
      "outputContract": "Return refined material and a short note on what changed.",
      "instructionTemplatePath": "creative-workbench.workflow.md"
    }
  ]
}
