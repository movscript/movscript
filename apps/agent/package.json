{
  "name": "movscript-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "movscript-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "pnpm --filter @movscript/draft-schemas build && tsc -p tsconfig.build.json && node scripts/build-server-bundle.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:generation-repair": "node --import tsx --test \"src/orchestration/toolExecutor.test.ts\"",
    "dev": "node scripts/dev-watch.mjs",
    "dev:cli": "tsx src/cli.ts",
    "start": "node dist/server.js",
    "cli": "node dist/cli.js"
  },
  "dependencies": {
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.2.9",
    "@movscript/draft-schemas": "workspace:*",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
