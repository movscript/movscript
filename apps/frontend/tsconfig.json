{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@movscript/draft-schemas": ["../../packages/draft-schemas/src/index.ts"],
      "@movscript/tokens": ["../../packages/tokens/src/index.ts"],
      "@movscript/ui": ["../../packages/ui/src/index.ts"],
      "@runtime": ["./src/runtime/community.tsx"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "electron"]
}
