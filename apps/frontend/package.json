{
  "name": "movscript-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:local": "node scripts/run-with-env.mjs MOVSCRIPT_BACKEND_POLICY=spawn MOVSCRIPT_AI_STREAM_DEBUG=1 pnpm run dev",
    "build": "node scripts/prepare-agent-deploy.mjs && electron-vite build",
    "dist": "pnpm run build && electron-builder --publish never",
    "test": "node ../../scripts/run-node-tests.mjs \"src/**/*.test.ts\" \"src/**/*.test.tsx\" \"electron/**/*.test.ts\"",
    "test:agent-run-debugging": "node ../../scripts/run-node-tests.mjs --suite agent-run-debugging && pnpm run typecheck",
    "test:generation-contract": "node ../../scripts/run-node-tests.mjs --suite generation-contract",
    "test:model-capability-contract": "pnpm run test:generation-contract && pnpm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "testSuites": {
    "agent-run-debugging": [
      "src/lib/agent*.test.ts",
      "src/lib/agent*.test.tsx",
      "src/lib/*Agent*.test.ts",
      "src/lib/jsonValue.test.ts",
      "src/store/agentStore.test.ts"
    ],
    "generation-contract": [
      "electron/mcp/*.test.ts",
      "electron/mcp/serverCandidateContract.test.ts",
      "src/lib/*eneration*.test.ts",
      "src/lib/*eneration*.test.tsx",
      "src/lib/agentCatalogCandidateContract.test.ts",
      "src/lib/agentGeneratedResultAttachments.test.ts",
      "src/lib/agentGeneratedResourceBinding.test.ts",
      "src/lib/assetCandidateQueryInvalidation.test.ts",
      "src/lib/contentWorkbenchUiContract.test.ts",
      "src/lib/agentMessageViewModel.test.ts",
      "src/lib/preProductionCandidateLockContract.test.ts",
      "src/lib/tasksCandidateSelectionContract.test.ts",
      "src/components/agent/GenerationCards.test.tsx"
    ]
  },
  "dependencies": {
    "@movscript/draft-schemas": "workspace:*",
    "@movscript/tokens": "workspace:*",
    "@movscript/ui": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.62.0",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "heic2any": "^0.0.4",
    "i18next": "^26.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.21"
  }
}
