{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@movscript/tokens": ["../../packages/tokens/src/index.ts"],
      "@movscript/ui": ["../../packages/ui/src/index.ts"],
      "@/*": ["../frontend/src/*"],
      "@admin/*": ["./src/*"],
      "@admin-edition": ["./src/edition/enterprise.tsx", "./src/edition/community.tsx"]
    }
  },
  "include": ["src", "../frontend/src/vite-env.d.ts", "../frontend/src/lib", "../frontend/src/store", "../frontend/src/types", "../frontend/src/i18n", "../frontend/src/components/ui", "../frontend/src/components/canvas"]
}
