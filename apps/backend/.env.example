DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=movscript
DB_DRIVER=postgres
DB_PATH=

SERVER_PORT=8765
MOVSCRIPT_APP_MODE=cloud
MOVSCRIPT_DATA_DIR=

# Required. Generate with:
# openssl rand -hex 32
ENCRYPTION_KEY=

# Required. Generate independently from ENCRYPTION_KEY:
# openssl rand -hex 32
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_HOURS=24

# Optional. When set, /mcp requires Authorization: Bearer <MCP_TOKEN>.
MCP_TOKEN=

# Object storage: minio or filesystem.
STORAGE_BACKEND=minio

# Used when STORAGE_BACKEND=filesystem. Defaults to $MOVSCRIPT_DATA_DIR/resources.
FILESYSTEM_STORAGE_ROOT=

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=movscript
MINIO_USE_SSL=false
